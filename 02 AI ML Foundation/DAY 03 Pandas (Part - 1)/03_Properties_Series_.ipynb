    "\n",
    "# 02 Vectorized Operation\n",
    "print(s1+s2)\n",
    "print()\n",
    "# print(s1*3)\n",
    "\n",
    "#03 Mutable Values and Immutable Size\n",
    "changed_s1 = s1.drop(0)\n",
    "s1[0] = 69\n",
    "print(s1)\n",
    "print(changed_s1)\n",
    "\n"
